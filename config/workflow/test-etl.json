        "conf": {
          "spark.sql.extensions": "io.delta.sql.DeltaSparkSessionExtension",
          "spark.kubernetes.namespace":"compute",
          "spark.kubernetes.container.image": "ghostwood/spark-engine:1.0.0",
          "spark.driver.extraClassPath": "/opt/airflow/jars/*",
          "spark.executor.extraClassPath": "/opt/spark/jars/*",
          "spark.sql.catalog.spark_catalog": "org.apache.spark.sql.delta.catalog.DeltaCatalog",
          "spark.sql.catalogImplementation": "hive",
          "spark.hadoop.hive.metastore.uris": "thrift://hive-metastore:9083",
          "spark.sql.warehouse.dir": "s3a://warehouse/",
          "spark.hadoop.fs.s3a.endpoint": "http://minio-svc-private.storage.svc.cluster.local:9000",
          "spark.hadoop.fs.s3a.access.key": "minioadmin",
          "spark.hadoop.fs.s3a.secret.key": "minioadmin",
          "spark.hadoop.fs.s3a.path.style.access": "true",
          "spark.hadoop.fs.s3a.impl": "org.apache.hadoop.fs.s3a.S3AFileSystem",
          "spark.sql.sources.partitionOverwriteMode": "dynamic",
          "spark.eventLog.enabled": "true",
          "spark.eventLog.dir": "s3a://spark-logs/events",
          "app.job_asset_bucket": "asset",
          "app.job_input_path": "job-input/source2bronze.json",
          "spark.jars.packages": "io.openlineage:openlineage-spark:1.7.0",
          "spark.extraListeners": "io.openlineage.spark.agent.OpenLineageSparkListener",
          "spark.openlineage.namespace": "onprem-spark",
          "spark.openlineage.transport.type": "kafka",
          "spark.openlineage.transport.topicName": "openlineage.events",
          "spark.openlineage.transport.properties.bootstrap.servers": "kafka.kafka.svc.cluster.local:9092",
          "spark.openlineage.debugFacet": "enabled"
